# Beyond Workz — Employer app
# Copy to .env and set values for your environment.

# Backend REST API (must include /api)
VITE_API_URL=http://localhost:5001/api

# Job seeker (employee) app origin — used in landing footer links
VITE_EMPLOYEE_APP_URL=http://localhost:5173

# Optional: Socket.io server URL (no /api). Defaults to API host if omitted.
# VITE_SOCKET_URL=http://localhost:5001
